{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openrecipestandard.org/schema/open-recipe.schema.json",
  "title": "Open Recipe Standard",
  "$comment": "Normative JSON Schema for the Open Recipe Standard: a portable, vendor-neutral format for encoding recipes for interchange between applications and libraries. All measurements use SI / metric units only (unit_system is always metric). quantity_kind selects the dimension; unit must be a standard metric code from the allowlist. base_yield (recipe output) only allows quantity_kind count, mass, or volume. Ingredient amounts are written for base_yield; scaling multiplies each amount by a scale factor. Provisional or vendor-specific fields use keys matching ^X-.",
  "type": "object",
  "required": ["recipe_name"],
  "properties": {
    "recipe_name": {
      "type": "string",
      "description": "Name of this recipe."
    },
    "recipe_uuid": {
      "type": "string",
      "description": "Stable identifier (e.g. vendor prefix + unique id) for this recipe instance."
    },
    "notes": {
      "$ref": "#/$defs/NotesList",
      "description": "Recipe-level notes."
    },
    "base_yield": {
      "$ref": "#/$defs/YieldMeasurement",
      "description": "What the written ingredient amounts produce (e.g. 24 cookies, 750 g batter, 2 L soup). Only count, mass, or volume—not temperature or duration. Metric only. To scale: multiply each ingredient amount by (target_yield_amount / base_yield.amount) when both use the same unit and quantity_kind, or by an explicit scale factor."
    },
    "ingredients": {
      "type": "array",
      "description": "Ingredients in order of use; repeat lines when used at different stages. Each amount is for base_yield unless scaled at display time.",
      "items": { "$ref": "#/$defs/Ingredient" }
    },
    "steps": {
      "type": "array",
      "description": "Ordered preparation steps.",
      "items": { "$ref": "#/$defs/Step" }
    },
    "oven_fan": {
      "type": "string",
      "enum": ["Off", "Low", "High"],
      "description": "Convection setting; if omitted, implementations may treat as Off."
    },
    "oven_temp": {
      "$ref": "#/$defs/Measurement",
      "description": "Starting oven temperature; quantity_kind temperature; unit C (degrees Celsius)."
    },
    "oven_time": {
      "$ref": "#/$defs/Measurement",
      "description": "Overall oven duration; quantity_kind duration; metric time units (min, s, h, etc.)."
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL this recipe was taken from, if applicable."
    },
    "source_authors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Original author(s) of the recipe, not the person who entered it."
    },
    "source_book": { "$ref": "#/$defs/SourceBook" }
  },
  "patternProperties": {
    "^X-": true
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "ingredients": {
            "type": "array",
            "minItems": 1
          }
        },
        "required": ["ingredients"]
      },
      "then": {
        "properties": {
          "base_yield": { "$ref": "#/$defs/YieldMeasurement" }
        },
        "required": ["base_yield"]
      }
    }
  ],
  "$defs": {
    "NotesList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "QuantityKind": {
      "type": "string",
      "enum": ["mass", "volume", "count", "temperature", "duration"],
      "description": "mass vs volume vs count; temperature (°C) and duration (s, min, h) for oven fields. Volume (ml, L) is never mass."
    },
    "UnitSystem": {
      "type": "string",
      "const": "metric",
      "description": "This standard only allows the metric system; value must be \"metric\"."
    },
    "Measurement": {
      "type": "object",
      "description": "A metric quantity: unit_system must be \"metric\". Field unit must be a standard code for quantity_kind (see allOf).",
      "required": ["amount", "unit", "quantity_kind", "unit_system"],
      "properties": {
        "amount": {
          "type": "number",
          "description": "Numeric amount in the given unit."
        },
        "unit": {
          "type": "string",
          "description": "Standard metric unit code for this quantity_kind."
        },
        "quantity_kind": { "$ref": "#/$defs/QuantityKind" },
        "unit_system": { "$ref": "#/$defs/UnitSystem" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "quantity_kind": { "const": "mass" } },
            "required": ["quantity_kind"]
          },
          "then": {
            "type": "object",
            "properties": {
              "unit": { "enum": ["mg", "g", "kg"] }
            }
          }
        },
        {
          "if": {
            "properties": { "quantity_kind": { "const": "volume" } },
            "required": ["quantity_kind"]
          },
          "then": {
            "type": "object",
            "properties": {
              "unit": { "enum": ["ml", "cl", "L"] }
            }
          }
        },
        {
          "if": {
            "properties": { "quantity_kind": { "const": "count" } },
            "required": ["quantity_kind"]
          },
          "then": {
            "type": "object",
            "properties": {
              "unit": {
                "enum": [
                  "each",
                  "dozen",
                  "serving",
                  "servings",
                  "portion",
                  "portions",
                  "cookie",
                  "cookies",
                  "slice",
                  "slices",
                  "egg",
                  "eggs",
                  "batch",
                  "batches",
                  "loaf",
                  "loaves",
                  "muffin",
                  "muffins"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "quantity_kind": { "const": "temperature" } },
            "required": ["quantity_kind"]
          },
          "then": {
            "type": "object",
            "properties": {
              "unit": { "enum": ["C"] }
            }
          }
        },
        {
          "if": {
            "properties": { "quantity_kind": { "const": "duration" } },
            "required": ["quantity_kind"]
          },
          "then": {
            "type": "object",
            "properties": {
              "unit": { "enum": ["ms", "s", "min", "h"] }
            }
          }
        }
      ]
    },
    "YieldMeasurement": {
      "description": "How much recipe output the written amounts represent. quantity_kind must be count, mass, or volume only. Metric only.",
      "allOf": [
        { "$ref": "#/$defs/Measurement" },
        {
          "type": "object",
          "properties": {
            "quantity_kind": {
              "type": "string",
              "enum": ["count", "mass", "volume"],
              "description": "Measure output as a number of items (count), total mass, or total volume."
            }
          }
        }
      ]
    },
    "IngredientSansSubstitutions": {
      "type": "object",
      "description": "Ingredient line without nested substitutions (used inside substitutions arrays).",
      "required": ["name", "amount"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable ingredient name."
        },
        "amount": {
          "$ref": "#/$defs/Measurement",
          "description": "Amount for base_yield; scale with the recipe when changing batch size."
        },
        "processing": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags like whole, minced, large dice."
        },
        "notes": { "$ref": "#/$defs/NotesList" },
        "usda_num": {
          "type": "string",
          "description": "USDA Standard Reference index key for nutrition lookup."
        }
      },
      "additionalProperties": false
    },
    "Ingredient": {
      "type": "object",
      "description": "Full ingredient line including optional substitutions.",
      "required": ["name", "amount"],
      "properties": {
        "name": { "type": "string" },
        "amount": { "$ref": "#/$defs/Measurement" },
        "processing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "$ref": "#/$defs/NotesList" },
        "usda_num": { "type": "string" },
        "substitutions": {
          "type": "array",
          "description": "Same shape as an ingredient but without substitutions on nested items.",
          "items": { "$ref": "#/$defs/IngredientSansSubstitutions" }
        }
      },
      "additionalProperties": false
    },
    "Haccp": {
      "description": "HACCP annotation: either control_point or critical_control_point, not both.",
      "oneOf": [
        {
          "type": "object",
          "required": ["control_point"],
          "properties": {
            "control_point": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["critical_control_point"],
          "properties": {
            "critical_control_point": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "Step": {
      "type": "object",
      "required": ["step"],
      "properties": {
        "step": {
          "type": "string",
          "description": "Instruction text for this step."
        },
        "notes": { "$ref": "#/$defs/NotesList" },
        "haccp": { "$ref": "#/$defs/Haccp" }
      },
      "additionalProperties": false
    },
    "SourceBook": {
      "type": "object",
      "properties": {
        "authors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Book author(s)."
        },
        "title": { "type": "string" },
        "isbn": { "type": "string" },
        "notes": { "$ref": "#/$defs/NotesList" }
      },
      "patternProperties": {
        "^X-": true
      },
      "additionalProperties": true
    }
  }
}
