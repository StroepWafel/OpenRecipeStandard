  "steps": [
    {
      "step": "In a large bowl, beat butter with granulated and brown sugars until light and fluffy, 2–3 minutes.",
      "notes": ["Scrape the bowl once halfway through."]
    },
    {
      "step": "Beat in the egg and vanilla until fully combined.",
      "haccp": {
        "control_point": "Use pasteurized eggs if serving to vulnerable populations; otherwise minimize time raw egg sits at room temperature."
      }
    },
    {
      "step": "In a separate bowl, whisk flour, baking soda, and salt.",
      "notes": ["Whisk thoroughly so baking soda is evenly distributed."]
    },
    {
      "step": "Stir dry ingredients into the butter mixture until just combined; do not overmix.",
      "notes": ["A few streaks of flour are fine before adding chips."]
    },
    {
      "step": "Fold in chocolate chips (or substitution) until evenly distributed."
    },
    {
      "step": "Cover and chill dough at least 30 minutes, or up to 48 hours."
    },
    {
      "step": "Preheat the oven and line baking sheets with parchment. Portion dough into mounds; leave space for spread.",
      "notes": ["A #40 scoop (~1.5 tbsp) works well for uniform cookies."]
    },
    {
      "step": "Bake until edges are set and centers look slightly underdone; cool on the sheet 5 minutes, then transfer to a rack.",
      "haccp": {
        "critical_control_point": "Cookies are safe when baked to a visibly set edge; for food-service settings, verify baked goods cooling and storage within 2 hours of leaving the oven."
      }
    }
  ],
